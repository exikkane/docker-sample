<?xml version="1.0"?>
<ruleset name="ProjectStaged">
    <description>Minimal PHPCS ruleset for staged project PHP files.</description>

    <rule ref="PSR12"/>

    <exclude-pattern>*/app/lib/*</exclude-pattern>
    <exclude-pattern>*/app/addons/*/lib/*</exclude-pattern>
    <exclude-pattern>*/var/*</exclude-pattern>
    <exclude-pattern>*/design/*</exclude-pattern>

    <arg name="colors"/>
</ruleset>
